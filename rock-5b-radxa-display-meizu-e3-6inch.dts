/dts-v1/;
/plugin/;

#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include <dt-bindings/display/drm_mipi_dsi.h>

/ {
	metadata {
		title ="Enable Meizu E3 1080x2160@6inch Display";
		compatible = "radxa,rock-5b";
		category = "display";
		exclusive = "dsi1";
		description = "Enable Meizu E3 1080x2160@6inch Display.";
	};

	fragment@0 {
		target-path = "/";

		__overlay__ {
			vcc_lcd_mipi1: vcc-lcd-mipi1 {
				status = "okay";
				compatible = "regulator-fixed";
				regulator-name = "vcc_lcd_mipi1";
				gpio = <&gpio1 RK_PC4 GPIO_ACTIVE_HIGH>;
				enable-active-high;
				regulator-boot-on;
				regulator-always-on;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};
		};
	};

	fragment@1 {
		target = <&pwm2>;

		__overlay__ {
			//status = "okay";
			//pinctrl-names = "active";
			//pinctrl-0 = <&pwm2m2_pins>;
		};
	};

	fragment@2 {
		target = <&dsi1>;

		__overlay__ {
			status = "okay";
			//rockchip,lane-rate = <480>;
			#address-cells = <1>;
			#size-cells = <0>;

			dsi1_panel: panel@0 {
				status = "okay";
				compatible = "simple-panel-dsi";
				reg = <0>;
				backlight = <&sgm37604_bl>;

				vdd-supply = <&vcc_lcd_mipi1>;
				vccio-supply = <&vcc_1v8_s0>;
				pinctrl-names = "default";
				pinctrl-0 = <&dsi1_lcd_rst_gpio>;
				reset-gpios = <&gpio0 RK_PC6 GPIO_ACTIVE_LOW>;
				
				prepare-delay-ms = <40>;
				reset-delay-ms = <60>;
				init-delay-ms = <80>;
				stbyb-delay-ms = <20>;
				enable-delay-ms = <60>;
				disable-delay-ms = <20>;
				unprepare-delay-ms = <20>;
				width-mm = <135>;
				height-mm = <216>;
				
				dsi,flags = <(MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_BURST | MIPI_DSI_MODE_LPM | MIPI_DSI_MODE_NO_EOT_PACKET | MIPI_DSI_CLOCK_NON_CONTINUOUS)>;
				//dsi,flags = <(MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_BURST | MIPI_DSI_MODE_LPM | MIPI_DSI_MODE_NO_EOT_PACKET)>;
				dsi,format = <MIPI_DSI_FMT_RGB888>;
				dsi,lanes  = <4>;
				panel-init-sequence = [
					05 78 01 11
					05 0A 01 29
				];

				panel-exit-sequence = [
					05 10 01 28
					05 78 01 10
				];

				disp_timings0: display-timings {
					native-mode = <&dsi_timing0>;
					dsi_timing0: timing0 {
						clock-frequency = <157000000>;
						hactive = <1080>;
						hfront-porch = <115>;
						hback-porch = <13>;
						hsync-len = <3>;
						vactive = <2160>;
						vfront-porch = <10>;
						vback-porch = <10>;
						vsync-len = <2>;
						hsync-active = <0>;
						vsync-active = <0>;
						de-active = <0>;
						pixelclk-active = <0>;
					};
				};
				
				ports {
					#address-cells = <1>;
					#size-cells = <0>;

					port@0 {
						reg = <0>;
						panel_in_dsi1: endpoint {
							remote-endpoint = <&dsi1_out_panel>;
						};
					};
				};
			};

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@1 {
					reg = <1>;
					dsi1_out_panel: endpoint {
						remote-endpoint = <&panel_in_dsi1>;
					};
				};
			};
		};
	};

	fragment@3 {
		target = <&mipi_dcphy1>;

		__overlay__ {
			status = "okay";
		};
	};

	fragment@4 {
		target = <&route_dsi1>;

		__overlay__ {
			status = "okay";
			connect = <&vp3_out_dsi1>;
		};
	};

	fragment@5 {
		target = <&dsi1_in_vp2>;

		__overlay__ {
			status = "disabled";
		};
	};

	fragment@6 {
		target = <&dsi1_in_vp3>;

		__overlay__ {
			status = "okay";
		};
	};

	fragment@7 {
		target = <&i2c6>;

		__overlay__ {
			status = "okay";
			pinctrl-names = "default";
			pinctrl-0 = <&i2c6m0_xfer>;
			clock-frequency = <400000>;
			#address-cells = <1>;
			#size-cells = <0>;

			sec_ts: sec_ts@48 {
				compatible = "sec,sec_ts";
				reg = <0x48>;
				status = "okay";
				pinctrl-names = "default";
				pinctrl-0 = <&ts_irq>;
				sec,irq_gpio = <&gpio0 RK_PD3 GPIO_ACTIVE_LOW>;
				sec,max_coords = <1080>, <2160>;
			};
			
			sgm37604_bl: backlight@36 {
				compatible = "sgmicro,sgm37604a";
				reg = <0x36>;
				status = "okay";
				pinctrl-names = "default";
				pinctrl-0 = <&dsi1_backlight_en>;
				sgmicro,led-channels = <0x07>;  // bit0 for dev_en and bit1~bit4 for led_channel1~led_channel4
				sgmicro,max-current = <0>;      // 00->25ma 01->30ma 10->35ma 11->40ma
				default-brightness-level = <128>;
				enable-gpios = <&gpio2 RK_PC1 GPIO_ACTIVE_HIGH>;
			};
		};
	};

	fragment@8 {
		target = <&pinctrl>;

		__overlay__ {
			dsi1-lcd {
				dsi1_lcd_rst_gpio: dsi1-lcd-rst-gpio {
					rockchip,pins = <0 RK_PC6 RK_FUNC_GPIO &pcfg_pull_none>; // <0 RK_PC6 RK_FUNC_GPIO &pcfg_pull_none> TP_RST_L  //<2 RK_PC1 RK_FUNC_GPIO &pcfg_pull_up> LCD_RST
				};

				dsi1_backlight_en: dsi1-backlight-en {
					rockchip,pins = <2 RK_PC1 RK_FUNC_GPIO &pcfg_pull_up>;  // <2 RK_PC2 RK_FUNC_GPIO &pcfg_pull_up> PWM_EN
				};
			};

			touch {
				ts_irq: ts-irq {
					rockchip,pins = <0 RK_PD3 RK_FUNC_GPIO &pcfg_pull_up>; //TP_INT_L
				};
			};
		};
	};
};
